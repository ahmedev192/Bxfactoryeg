generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PLANNER
  PRODUCTION_MANAGER
  VIEWER
}

enum OrderStatus {
  DRAFT
  PLANNED
  RELEASED
  IN_PRODUCTION
  COMPLETED
  ARCHIVED
}

enum ScenarioType {
  FASTEST_TIME
  LOWEST_COST
  BALANCED
  MOST_RELIABLE
  CUSTOM
}

enum StepType {
  FABRIC
  PRINT
  FACTORY
}

enum FieldType {
  TEXT
  DATE
  NUMBER
  TEXTAREA
  DROPDOWN
}

enum VendorType {
  FACTORY
  PRINTING_PLACE
  FABRIC_SUPPLIER
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         UserRole      @default(PLANNER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orders       Order[]
  planningRuns PlanningRun[]
  auditLogs    AuditLog[]
  pdfExports   PdfExport[]
}

model Factory {
  id              String             @id @default(uuid())
  name            String
  processingDays  Decimal            @db.Decimal(10, 2)
  costPerUnit     Decimal            @db.Decimal(10, 2)
  fixedCost       Decimal            @default(0) @db.Decimal(10, 2)
  confidencePct   Decimal            @default(80) @db.Decimal(5, 2)
  isActive        Boolean            @default(true)
  isSplittable    Boolean            @default(false)
  minSplitPct     Decimal            @default(10) @db.Decimal(5, 2)
  maxSplits       Int                @default(2)
  capacityPerDay  Int?
  categories      String?            @db.Text
  notes           String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  fieldTemplates  FieldTemplate[]
}

model PrintingPlace {
  id              String             @id @default(uuid())
  name            String
  processingDays  Decimal            @db.Decimal(10, 2)
  costPerUnit     Decimal            @db.Decimal(10, 2)
  fixedCost       Decimal            @default(0) @db.Decimal(10, 2)
  confidencePct   Decimal            @default(80) @db.Decimal(5, 2)
  isActive        Boolean            @default(true)
  isSplittable    Boolean            @default(false)
  minSplitPct     Decimal            @default(10) @db.Decimal(5, 2)
  maxSplits       Int                @default(2)
  printTypes      String?            @db.Text
  notes           String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model FabricSupplier {
  id              String             @id @default(uuid())
  name            String
  processingDays  Decimal            @db.Decimal(10, 2)
  costPerUnit     Decimal            @db.Decimal(10, 2)
  fixedCost       Decimal            @default(0) @db.Decimal(10, 2)
  confidencePct   Decimal            @default(80) @db.Decimal(5, 2)
  isActive        Boolean            @default(true)
  isSplittable    Boolean            @default(false)
  minSplitPct     Decimal            @default(10) @db.Decimal(5, 2)
  maxSplits       Int                @default(2)
  moq             Int?
  notes           String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model GlobalSettings {
  id                  String   @id @default("default")
  companyName         String   @default("شركة الإنتاج")
  currency            String   @default("EGP")
  defaultConfidence   Decimal  @default(80) @db.Decimal(5, 2)
  transportBufferDays Int      @default(1)
  maxVendorsPerStep   Int      @default(2)
  workingDaysJson     String   @default("[1,2,3,4,5]") @db.Text
  holidaysJson        String   @default("[]") @db.Text
  categoryPresets     String   @default("[]") @db.Text
  printTypePresets    String   @default("[]") @db.Text
  updatedAt           DateTime @updatedAt
}

model Order {
  id                  String            @id @default(uuid())
  orderNo             String            @unique
  status              OrderStatus       @default(DRAFT)
  deadline            DateTime?
  totalQty            Int               @default(0)
  notes               String?           @db.Text
  category            String?
  requiredPrintType   String?
  selectedScenarioId  String?           @unique
  createdById         String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  createdBy           User              @relation(fields: [createdById], references: [id])
  selectedScenario    Scenario?         @relation("SelectedScenario", fields: [selectedScenarioId], references: [id])
  fields              OrderField[]
  matrixCells         OrderMatrixCell[]
  photos              OrderPhoto[]
  planningRuns        PlanningRun[]
  pdfExports          PdfExport[]
  actualPerformances  ActualPerformance[]
  colors              String            @default("[]") @db.Text
  sizes               String            @default("[]") @db.Text
}

model OrderField {
  id         String    @id @default(uuid())
  orderId    String
  label      String
  value      String    @default("") @db.Text
  fieldType  FieldType @default(TEXT)
  sortOrder  Int       @default(0)
  isRequired Boolean   @default(false)
  options    String?   @db.Text
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderMatrixCell {
  id       String @id @default(uuid())
  orderId  String
  color    String
  size     String
  quantity Int    @default(0)
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, color, size])
  @@index([orderId])
}

model OrderPhoto {
  id        String   @id @default(uuid())
  orderId   String
  filename  String
  path      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model PlanningRun {
  id              String     @id @default(uuid())
  orderId         String
  runById         String
  deadline        DateTime
  quantity        Int
  customWeights   String?    @db.Text
  constraintsJson String?    @db.Text
  createdAt       DateTime   @default(now())
  order           Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  runBy           User       @relation(fields: [runById], references: [id])
  scenarios       Scenario[]

  @@index([orderId])
}

model Scenario {
  id              String       @id @default(uuid())
  planningRunId   String
  type            ScenarioType
  totalDays       Int
  totalCost       Decimal      @db.Decimal(12, 2)
  certaintyPct    Decimal      @db.Decimal(5, 2)
  p50Days         Int?
  p90Days         Int?
  meetsDeadline   Boolean
  splitCount      Int          @default(0)
  deadlineRiskPct Decimal?     @db.Decimal(5, 2)
  vendorSummary   String       @db.Text
  planningRun     PlanningRun  @relation(fields: [planningRunId], references: [id], onDelete: Cascade)
  steps           RouteStep[]
  selectedForOrder Order?      @relation("SelectedScenario")

  @@index([planningRunId])
}

model RouteStep {
  id            String          @id @default(uuid())
  scenarioId    String
  stepOrder     Int
  stepType      StepType
  vendorType    VendorType
  vendorId      String
  vendorName    String
  startDate     DateTime
  endDate       DateTime
  days          Int
  cost          Decimal         @db.Decimal(12, 2)
  confidencePct Decimal         @db.Decimal(5, 2)
  parallelGroup Int?
  scenario      Scenario        @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  splits        RouteSplit[]
  actuals       ActualPerformance[]

  @@index([scenarioId])
}

model RouteSplit {
  id          String    @id @default(uuid())
  routeStepId String
  vendorId    String
  vendorName  String
  splitPct    Decimal   @db.Decimal(5, 2)
  quantity    Int
  days        Int
  cost        Decimal   @db.Decimal(12, 2)
  routeStep   RouteStep @relation(fields: [routeStepId], references: [id], onDelete: Cascade)

  @@index([routeStepId])
}

model ActualPerformance {
  id           String     @id @default(uuid())
  orderId      String
  routeStepId  String?
  stepType     StepType
  vendorType   VendorType
  vendorId     String
  vendorName   String
  plannedDays  Int
  actualDays   Int
  plannedCost  Decimal    @db.Decimal(12, 2)
  actualCost   Decimal    @db.Decimal(12, 2)
  recordedAt   DateTime   @default(now())
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  routeStep    RouteStep? @relation(fields: [routeStepId], references: [id])

  @@index([orderId])
  @@index([vendorId])
}

model VendorStatistics {
  id            String     @id @default(uuid())
  vendorType    VendorType
  vendorId      String
  sampleCount   Int        @default(0)
  meanDays      Decimal    @default(0) @db.Decimal(10, 2)
  stdDays       Decimal    @default(0) @db.Decimal(10, 2)
  meanCost      Decimal    @default(0) @db.Decimal(12, 2)
  stdCost       Decimal    @default(0) @db.Decimal(12, 2)
  confidencePct Decimal    @default(80) @db.Decimal(5, 2)
  updatedAt     DateTime   @updatedAt

  @@unique([vendorType, vendorId])
}

model FieldTemplate {
  id        String              @id @default(uuid())
  name      String
  factoryId String?
  factory   Factory?            @relation(fields: [factoryId], references: [id])
  items     FieldTemplateItem[]
  createdAt DateTime            @default(now())
}

model FieldTemplateItem {
  id         String        @id @default(uuid())
  templateId String
  label      String
  fieldType  FieldType     @default(TEXT)
  sortOrder  Int           @default(0)
  isRequired Boolean       @default(false)
  options    String?       @db.Text
  template   FieldTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model PdfExport {
  id         String   @id @default(uuid())
  orderId    String
  exportedBy String
  filename   String
  orient     String   @default("p")
  inclPhotos Boolean  @default(true)
  filePath   String?
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [exportedBy], references: [id])

  @@index([orderId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  details    String?  @db.Text
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
}
